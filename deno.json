{
	"tasks": {
		"start": "deno run -A --env-file=.env src/index.ts",
		"dev": "deno run -A --env-file=.env --watch src/index.ts",
		"dev:cobalt": "podman-compose --profile local-cobalt up --force-recreate cobalt",
		"dev:cobalt-api": "deno run -A --env-file=.env --watch src/dev/cobalt-function.ts",
		"dev:local": "bash scripts/dev-local.sh",
		"function:install": "npm --prefix azure-functions/cobalt-proxy install",
		"function:start": "npm --prefix azure-functions/cobalt-proxy start",
		"function:publish": "npm --prefix azure-functions/cobalt-proxy run publish --",
		"check": "deno check src/index.ts src/migrations/add-chat-settings.ts src/dev/cobalt-function.ts",
		"format": "deno run -A @biomejs/biome lint . --write; deno run -A @biomejs/biome format . --write",
		"verify": "deno run -A @biomejs/biome check . && deno check src/index.ts src/migrations/add-chat-settings.ts src/dev/cobalt-function.ts",
		"migrate:add-chat-settings": "deno run -A --env-file=.env src/migrations/add-chat-settings.ts"
	},
	"imports": {
		"@biomejs/biome": "npm:@biomejs/biome@1.9.4",
		"@grammyjs/auto-retry": "npm:@grammyjs/auto-retry@2.0.2",
		"@grammyjs/i18n": "npm:@grammyjs/i18n@0.5.1",
		"@grammyjs/runner": "npm:@grammyjs/runner@2.0.3",
		"grammy": "npm:grammy@1.43.0",
		"mongodb": "npm:mongodb@4.17.2",
		"youtube-dl-exec": "npm:youtube-dl-exec@3.1.6"
	}
}
